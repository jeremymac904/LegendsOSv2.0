# ============================================================================
# LegendsOS 2.0 — Environment Variables
# ============================================================================
# Copy this file to `.env.local` and fill in the real values.
# Never commit `.env.local` or any file with real secrets.
# ----------------------------------------------------------------------------

# ---- Supabase --------------------------------------------------------------
# Public values (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Preferred (new Supabase API key UI):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Legacy fallback (older Supabase projects). Either one works.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (NEVER expose to the browser)
# Preferred (new Supabase API key UI):
SUPABASE_SECRET_KEY=your-secret-key
# Legacy fallback (older Supabase projects). Either one works.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- AI Provider Gateway (server-only) -------------------------------------
# OpenRouter — general LLM routing for Atlas chat, copy generation, etc.
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# DeepSeek — coding/reasoning use cases (optional, can also flow via OpenRouter)
DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# NVIDIA NIM — optional hosted inference
NVIDIA_API_KEY=
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODEL_NEMOTRON_SUPER_1=
# NVIDIA_MODEL_MISTRAL_SMALL_4=
# NVIDIA_MODEL_KIMI_K2=

# MiniMax — optional (code paths exist; activate by setting key + enable flag)
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_DEFAULT_MODEL=MiniMax-M2.7
# AI_ENABLE_MINIMAX=false

# HuggingFace — optional (token recognised; no gateway routing yet)
# HF_TOKEN=
# HUGGINGFACE_DEFAULT_MODEL=

# Fal.ai — image generation
FAL_KEY=
FAL_DEFAULT_MODEL=fal-ai/flux/schnell
# FAL_DEFAULT_IMAGE_MODEL=fal-ai/flux/schnell
# FAL_FAST_IMAGE_MODEL=fal-ai/flux/schnell
# FAL_PREMIUM_IMAGE_MODEL=fal-ai/flux-pro

# Provider defaults (override which provider is used by default)
# AI_DEFAULT_TEXT_PROVIDER=openrouter
# AI_DEFAULT_IMAGE_PROVIDER=fal

# Extra OpenRouter free-tier model slots
# OPENROUTER_FREE_MODEL_1=
# OPENROUTER_FREE_MODEL_2=
# OPENROUTER_FREE_MODEL_3=
# OPENROUTER_FREE_MODEL_4=

# DeepSeek base URL override
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# OpenRouter base URL override
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- n8n Automation Layer (server-only) ------------------------------------
# The simplified n8n workflows accept plain JSON POSTs. No HMAC. No shared
# secret. External actions remain gated by ALLOW_LIVE_* below.
N8N_WEBHOOK_BASE_URL=https://n8n.srv1124745.hstgr.cloud
# Legacy alias — kept for backward compatibility; same value as above.
N8N_BASE_URL=https://n8n.srv1124745.hstgr.cloud

# Per-workflow webhook URLs. If empty, the app records the request as a
# queued automation_job but does not call out.
N8N_WEBHOOK_SOCIAL_PUBLISH=https://n8n.srv1124745.hstgr.cloud/webhook/legendsos/social-publish
N8N_WEBHOOK_EMAIL_SEND=https://n8n.srv1124745.hstgr.cloud/webhook/legendsos/email-send
N8N_WEBHOOK_DAILY_USAGE=https://n8n.srv1124745.hstgr.cloud/webhook/legendsos/daily-usage
N8N_WEBHOOK_PROVIDER_HEALTH=https://n8n.srv1124745.hstgr.cloud/webhook/legendsos/provider-health
N8N_WEBHOOK_CONTENT_REMINDER=https://n8n.srv1124745.hstgr.cloud/webhook/legendsos/content-reminder
N8N_WEBHOOK_FAILED_PUBLISH_RECOVERY=https://n8n.srv1124745.hstgr.cloud/webhook/legendsos/failed-publish-recovery

# ---- Google OAuth (server-only) --------------------------------------------
# Required for Gmail, Drive, Calendar integrations. Create a Google Cloud
# project with OAuth consent screen. Leave blank to show "Coming Soon" in UI.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://legendsos.app/api/integrations/google/callback
# OAUTH_STATE_SECRET=random-32-char-secret

# ---- Meta / Facebook (server-only) ----------------------------------------
# Required for direct Facebook/Instagram publishing. Needs App Review.
# META_APP_ID=
# META_APP_SECRET=

# ---- Zapier MCP (server-only) ---------------------------------------------
# ZAPIER_MCP_KEY=
# ZAP_MCP_KEY=
# ZAP_MCP_URL=

# ---- Telegram (server-only) -----------------------------------------------
# TELEGRAM_BOT_TOKEN=

# ---- GOAT Command API (server-only) ---------------------------------------
# Shared secret for Custom GPT Actions. 14 endpoints under /api/goat/*.
# GOAT_COMMAND_API_KEY=

# ---- Browser Companion Extension (server-only) ----------------------------
# Comma-separated allowed origins for the browser extension CORS.
# LEGENDSOS_BROWSER_EXTENSION_ORIGINS=chrome-extension://your-extension-id

# ---- Webhook Security (server-only) ---------------------------------------
# HMAC secret for verifying inbound webhooks (email intake, n8n callbacks).
# LEGENDSOS_WEBHOOK_SECRET=

# ---- Scheduled Functions (server-only) ------------------------------------
# Shared secret for Netlify scheduled functions.
# CRON_SECRET=

# ---- Loan Brain (server-only) ---------------------------------------------
# LOAN_MEMORY_ENABLED=true
# LOAN_BRAIN_DRIVE_READONLY=false
# LOAN_BRAIN_PIPELINE_FOLDER_URL=

# ---- App configuration -----------------------------------------------------
# Owner email is granted the `owner` role automatically on first profile insert.
NEXT_PUBLIC_OWNER_EMAIL=jeremy@mcdonald-mtg.com
NEXT_PUBLIC_APP_NAME="LegendsOS"
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=https://legendsos.app
NEXT_PUBLIC_TEAM_NAME="The Legends Mortgage Team powered by Loan Factory"
# NEXT_PUBLIC_BRAND_LINE="The Legends Mortgage Team"
NEXT_PUBLIC_COMPLIANCE_LINE="Jeremy McDonald, NMLS 1195266, The Legends Mortgage Team powered by Loan Factory, NMLS 320841."
# NEXT_PUBLIC_KNOWLEDGE_TUTORIAL_URL=

# ---- Optional public-facing media ----------------------------------------
# Welcome video embedded on /login (left panel). Use a vimeo / youtube / loom
# embed URL. If empty, /login shows a "Welcome video coming soon" placeholder.
# NEXT_PUBLIC_WELCOME_VIDEO_URL=https://player.vimeo.com/video/000000000

# Desktop app download URLs surfaced on /login. If either is empty, the
# matching button shows "Coming soon" and is disabled. No app wrapping
# happens automatically — point these at the hosted .dmg / .exe / .msi when
# the desktop wrapper is built.
# NEXT_PUBLIC_DESKTOP_MAC_DOWNLOAD_URL=https://cdn.example.com/LegendsOS.dmg
# NEXT_PUBLIC_DESKTOP_WINDOWS_DOWNLOAD_URL=https://cdn.example.com/LegendsOS.exe

# ---- Daily caps (server-only) ---------------------------------------------
DAILY_CAP_CHAT_MESSAGES=100
DAILY_CAP_IMAGE_GENERATIONS=10
DAILY_CAP_SOCIAL_POSTS=50
DAILY_CAP_EMAIL_DRAFTS=25

# ---- Safety flags (server-only) -------------------------------------------
# Hard-blocks real publish/send/spend even if integrations are wired.
# Set to `true` only after Jeremy explicitly green-lights live actions.
ALLOW_LIVE_SOCIAL_PUBLISH=false
ALLOW_LIVE_EMAIL_SEND=false
ALLOW_PAID_IMAGE_GENERATION=false
ALLOW_PAID_TEXT_GENERATION=false
