{
  "name": "legendsos-v2",
  "version": "2.0.0",
  "private": true,
  "description": "LegendsOS 2.0 \u2014 internal AI operating system for The Legends Mortgage Team powered by Loan Factory.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:loan-memory": "tsx tests/loan-memory/run.ts",
    "test:e2e:install": "playwright install --with-deps chromium",
    "index-assets": "tsx scripts/index-local-assets.ts",
    "seed-assistants": "tsx scripts/seed-atlas-assistants-from-local.ts",
    "ingest-twins": "node scripts/ingest-ai-twins.mjs",
    "import-local-knowledge": "tsx scripts/import-local-knowledge.ts",
    "desktop:dev": "electron .",
    "desktop:dev:local": "LEGENDSOS_DESKTOP_URL=http://localhost:3000 electron .",
    "desktop:build": "electron-builder",
    "desktop:build:mac": "electron-builder --mac dmg --publish never && node scripts/repair-mac-test-build.mjs",
    "desktop:build:windows": "electron-builder --win nsis --publish never",
    "desktop:rebuild-icon": "sips -z 384 768 public/assets/logos/legends-os-logo.png --out /tmp/legendsos-icon-sized.png > /dev/null && sips --padToHeightWidth 1024 1024 --padColor 0a0a0d /tmp/legendsos-icon-sized.png --out electron/icon.png > /dev/null && echo 'electron/icon.png regenerated'"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.105.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.451.0",
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "tsx": "^4.19.1",
    "dotenv": "^16.4.5"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "build": {
    "appId": "com.legendsmortgage.legendsos",
    "productName": "LegendsOS",
    "copyright": "Copyright \u00a9 2026 The Legends Mortgage Team powered by Loan Factory",
    "asar": true,
    "files": [
      "**/*",
      "!node_modules/**/*",
      "!.next/**/*"
    ],
    "directories": {
      "app": "electron",
      "buildResources": "electron",
      "output": "dist-desktop"
    },
    "mac": {
      "category": "public.app-category.business",
      "icon": "electron/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "LSMinimumSystemVersion": "11.0.0"
      }
    },
    "dmg": {
      "title": "LegendsOS ${version}",
      "icon": "electron/icon.png",
      "background": null,
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "electron/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "The Legends Mortgage Team"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "LegendsOS"
    },
    "linux": {
      "icon": "electron/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
